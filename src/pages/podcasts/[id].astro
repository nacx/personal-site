---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackButton from "@/components/BackButton.astro";
import { SITE } from "@/config";
import { extractYouTubeId } from "@/utils/youtube";

export async function getStaticPaths() {
  const podcasts = await getCollection("podcasts");
  return podcasts.map(podcast => ({ params: { id: podcast.id }, props: { podcast } }));
}

const { podcast } = Astro.props;
const { title, host, event, date, description, link, audioLink, videoLink } = podcast.data;
const { Content } = await render(podcast);

const youtubeId = videoLink ? extractYouTubeId(videoLink) : null;
const isYouTube = youtubeId !== null;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
});
---

<Layout title={`${title} | ${SITE.title}`} description={description}>
  <Header />
  <BackButton href="/podcasts" label="Podcasts" />
  <main id="main-content" class="app-layout pb-12">
    <h1 class="text-2xl font-bold text-accent sm:text-3xl mt-4">{title}</h1>
    <p class="mt-2 opacity-60 text-sm">
      {host}{event ? ` · ${event}` : ""} &mdash; {formattedDate}
    </p>

    <div class="mt-4 flex flex-wrap gap-3">
      <a
        href={link}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm border border-border rounded px-3 py-1 hover:text-accent hover:border-accent transition-colors"
      >
        Episode Page
      </a>
      {audioLink && (
        <a
          href={audioLink}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm border border-border rounded px-3 py-1 hover:text-accent hover:border-accent transition-colors"
        >
          Audio
        </a>
      )}
      {videoLink && (
        <a
          href={videoLink}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm border border-border rounded px-3 py-1 hover:text-accent hover:border-accent transition-colors"
        >
          Video
        </a>
      )}
    </div>

    <article class="app-prose mt-8 w-full max-w-app">
      <Content />
    </article>

    <!-- YouTube embed -->
    {isYouTube && (
      <div class="mt-8 aspect-video w-full">
        <iframe
          src={`https://www.youtube.com/embed/${youtubeId}`}
          title={title}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="w-full h-full rounded-lg"
        ></iframe>
      </div>
    )}

    <!-- Non-YouTube video link fallback -->
    {videoLink && !isYouTube && (
      <div class="mt-8 aspect-video w-full">
        <iframe
          src={videoLink}
          title={title}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="w-full h-full rounded-lg"
        ></iframe>
      </div>
    )}
  </main>
  <Footer />
</Layout>
