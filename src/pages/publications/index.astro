---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SectionItem from "@/components/SectionItem.astro";
import { SITE } from "@/config";

const publications = await getCollection("publications");
---

<Layout title={`Publications | ${SITE.title}`} description="Academic papers and research publications">
  <Header />
  <main id="main-content" class="app-layout">
    <section class="pt-8 pb-6 border-b border-border">
      <h1 class="text-3xl font-bold sm:text-4xl">Publications</h1>
      <p class="mt-2 opacity-60">Academic papers and research publications</p>
    </section>
    <section class="pt-8 pb-12">
      <ul>
        {publications.map(pub => (
          <SectionItem
            title={pub.data.title}
            href={`/publications/${pub.id}`}
            subtitle={pub.data.authors}
            description={pub.data.description}
          />
        ))}
      </ul>
    </section>
  </main>
  <Footer />
</Layout>
